# ── Always include (negations must come after excludes) ──

# Dependencies (will be installed in container)
node_modules
**/node_modules

# Build artifacts
**/dist
**/.next
**/.turbo

# Dev / IDE
.git
.gitignore
.vscode

# Env files
.env
.env.*
**/.env
**/.env.*

# Docs & memory
memory/
README.md
LICENSE

# Frontend app (not needed for worker)
apps/chat/
convex/

# Tests
**/__tests__
**/*.test.*
**/*.spec.*

# ── Ensure critical files are NOT excluded ──
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
