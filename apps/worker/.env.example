# Server
PORT=3001
NODE_ENV=development

# Convex
CONVEX_URL=

# WhatsApp (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_ACCESS_TOKEN=your_meta_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Meta Webhook Security
META_APP_SECRET=your_meta_app_secret

# OpenRouter (LLM)
OPENROUTER_API_KEY=your_openrouter_api_key
LLM_MODEL=deepseek/deepseek-chat-v3-0324
LLM_PROVIDER_PRIORITY=deepinfra
LLM_PROVIDER_ALLOW_FALLBACKS=true
LLM_ENABLE_REASONING_COMPLEX=true

# Supabase (for appointments AND OTP)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# OTP Security
OTP_HASH_SECRET=your_random_64_char_hex_secret
INTERNAL_API_KEY=your_internal_api_key_for_musait_app

# Application
APP_BASE_URL=

# Telegram (for human override notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
